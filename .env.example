# No More Groceries — Environment Variables Template
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.

# ── API Server ──────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# ── PC Express (future live API integration) ────────────────────────────────
# PC_EXPRESS_API_KEY=your_api_key_here
# PC_EXPRESS_API_SECRET=your_api_secret_here
# PC_EXPRESS_BASE_URL=https://api.pcexpress.ca

# ── Database ─────────────────────────────────────────────────────────────────
# DB_PATH=./data/groceries.db   # default; override for custom location

# ── Daily Refresh Cron ───────────────────────────────────────────────────────
# REFRESH_POSTAL_CODES=H2X 1Y4,K1A 0A6   # comma-separated postal codes to fetch
